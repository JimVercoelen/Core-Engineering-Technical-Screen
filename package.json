{
  "name": "core-engineering-technical-screen",
  "version": "1.0.0",
  "type": "module",
  "main": "dist/utils/sort.js",
  "scripts": {
    "build": "tsc",
    "test": "jest",
    "dev": "vite",
    "build:web": "vite build",
    "lint": "eslint src/",
    "lint:fix": "eslint src/ --fix",
    "format": "prettier --write \"src/**/*.{ts,tsx}\"",
    "format:check": "prettier --check \"src/**/*.{ts,tsx}\"",
    "prepare": "husky"
  },
  "lint-staged": {
    "*.{ts,tsx}": [
